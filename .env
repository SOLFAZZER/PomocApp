# ── BASE DE DATOS ──────────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/pomocapp"

# ── JWT ────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="USC123"
JWT_EXPIRES_IN="7d"

# ── SERVIDOR ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CLOUDINARY (archivos adjuntos) ─────────────────────────
# Regístrate gratis en cloudinary.com y copia tus credenciales
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# ── FRONTEND ───────────────────────────────────────────────
# URL del frontend para configurar CORS
FRONTEND_URL="http://localhost:5500"
